rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, googleAdsToken, metaAdsToken, createdAt
    //
    // Collection: campaigns
    // Fields: id, name, platform, status, budget, spent, clicks, conversions, lastUpdated, createdBy
    //
    // Collection: optimizations
    // Fields: campaignId, recommendation, predictedImpact, applied, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.createdBy;
    }

    function isUserDocOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255;
    }

    function isValidCampaign(data) {
      return data.keys().hasAll(['name', 'platform', 'budget', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.platform in ['Google', 'Meta'] &&
             data.budget is number && data.budget >= 0 &&
             data.createdBy == request.auth.uid;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.createdBy == request.auth.uid);
      allow create: if isAuthenticated() && isValidCampaign(request.resource.data);
      allow update: if isAuthenticated() && resource.data.createdBy == request.auth.uid && isValidCampaign(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.createdBy == request.auth.uid;
    }

    match /optimizations/{optId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
    }
  }
}
