rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Ownership model
    // ===============================================================
    // Every owner-scoped collection stores `createdBy: <uid>`. A document is
    // readable/writable only by its owner. List queries must include
    // where("createdBy","==",uid) or Firestore rejects the whole query.
    //
    // Server-only collections (written by the Admin SDK, which bypasses rules)
    // have NO match block on purpose: default-deny keeps them client-inaccessible.
    // Do not add rules for: clicks, conversions, conversion_reports,
    // antifraud_logs, settings, integrations, ecommerce_nodes, workflow_rules,
    // filter_rules, import_jobs, alerts.
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function ownsExisting() {
      return isSignedIn() && resource.data.createdBy == request.auth.uid;
    }
    function ownsIncoming() {
      return isSignedIn() && request.resource.data.createdBy == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 255;
    }

    // --- users: each user owns their own doc keyed by uid ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // --- campaigns: owner-scoped; owner cannot be reassigned on update ---
    match /campaigns/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming()
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- advertisers ---
    match /advertisers/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- publishers ---
    match /publishers/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- smartlinks ---
    match /smartlinks/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- saved_reports ---
    match /saved_reports/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- team_members ---
    match /team_members/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- goals ---
    match /goals/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- creatives ---
    match /creatives/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- coupons ---
    match /coupons/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- approvals ---
    match /approvals/{id} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming();
      allow update: if ownsExisting()
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if ownsExisting();
    }

    // --- optimizations (left as-is from prior version) ---
    match /optimizations/{optId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
