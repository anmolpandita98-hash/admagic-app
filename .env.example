# GEMINI_API_KEY: Server-side key for Gemini (Neuro Creative Lab + AI Insights).
# This is used ONLY on the server and is never exposed to the browser.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_APPLICATION_CREDENTIALS: Absolute path to a Firebase service-account
# JSON. Required for the Admin SDK (Firestore + ID token verification). The
# server boots without it but 500s on the first Firestore call, so set it.
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"

# PORT: Port the Express server listens on (defaults to 3000).
PORT="3000"

# META_ADS_CLIENT_ID: Public client ID for Meta Ads integration (not a secret).
META_ADS_CLIENT_ID="MY_META_CLIENT_ID"

# GOOGLE_ADS_CLIENT_ID: Public client ID for Google Ads integration (not a secret).
GOOGLE_ADS_CLIENT_ID="MY_GOOGLE_CLIENT_ID"
