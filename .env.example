# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# META_ADS_CLIENT_ID: Client ID for Meta Ads integration
META_ADS_CLIENT_ID="MY_META_CLIENT_ID"

# GOOGLE_ADS_CLIENT_ID: Client ID for Google Ads integration
GOOGLE_ADS_CLIENT_ID="MY_GOOGLE_CLIENT_ID"

# APP_SECRET_KEY: Used for session encryption
APP_SECRET_KEY="MY_SECRET_KEY"
